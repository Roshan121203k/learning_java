<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context-3.0.xsd">

    <!-- Enable annotation support -->
    <context:annotation-config/>
	<bean id="department" class="com.training.org.Organization">
        <property name="deptId" value="101"/>
        <property name="deptName" value="fgh"/>
        <property name="deptLocation" value="Pune"/>
    </bean>
    <!-- Customer Bean -->
    <bean id="customerBean" class="com.training.org.Employee">
        <property name="empId" value="101"/>
        <property name="name" value="Anand"/>
       
    </bean>

</beans>